<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zeroone.star.stumanager.mapper.ContactRecordMapper">
    <select id="selectByStudentId" resultType="com.zeroone.star.stumanager.entity.ContactRecord">
        SELECT * FROM contact_record WHERE student_id = #{studentId} AND deleted = 0 ORDER BY add_time DESC
    </select>
</mapper>
